{
  "name": "asen-khai-kalyan-tahobil",
  "version": "1.0.0",
  "description": "আসেন খাই কল্যাণ তহবিল - Share and Welfare Fund Management App",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node src/db/seed.js",
    "seed:fresh": "node -e \"const fs=require('fs'),path=require('path');const p=path.resolve(process.env.DB_PATH||'./data/welfare_fund.db');if(fs.existsSync(p))fs.unlinkSync(p);\" && node src/db/seed.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "google-auth-library": "^10.7.0",
    "google-spreadsheet": "^5.3.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^9.0.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
